{
  "name": "focusdot",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:installer",
    "build:prod": "tsc && vite build --mode production",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:frontend && npm run test:rust",
    "test:frontend": "vitest run --environment jsdom",
    "test:rust": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cargo-path.ps1 test --manifest-path src-tauri/Cargo.toml",
    "tauri": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-tauri.ps1",
    "build:installer": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-tauri.ps1 build",
    "build:msi": "npm run typecheck && npm test && npm run build:installer"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0"
  },
  "devDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.60.2",
    "@tauri-apps/cli": "^2.0.0",
    "@tauri-apps/cli-win32-x64-msvc": "^2.10.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.0.0",
    "jsdom": "^24.1.1",
    "typescript": "^5.5.4",
    "vite": "^6.4.2",
    "vitest": "^3.0.5"
  }
}
